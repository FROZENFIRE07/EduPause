# ==========================
# Root .gitignore — MasteryOS
# ==========================

# Environment variables (contain secrets)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pip_log.txt
pip_output.txt
build_log.txt

# Node
node_modules/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Byte-compiled
*.pyc
*.pyo

# Distribution
dist/
dist-ssr/

# Misc
*.local
.cache/
